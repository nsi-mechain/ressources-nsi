        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x = np.linspace(0, 2 * np.pi, 100)\n",
        "y = np.sin(x)\n",
        "\n",
        "plt.plot(x, y)\n",
        "plt.title(\"Sinusoïde\")\n",
        "plt.grid(True)\n",
        "plt.show()\n",
        "print(\"Terminé.\")"
      ]
